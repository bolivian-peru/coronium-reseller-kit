# Your Coronium API key (JWT). Get it from https://dashboard.coronium.io → Settings → API.
# This stays server-side — never exposed to the browser.
CORONIUM_API_KEY=

# Base URL for the Coronium API. Default is production; override only if testing
# against a different environment.
CORONIUM_API_BASE=https://api.coronium.io/api/v3

# The public URL of THIS reseller dashboard. Used to register the webhook
# with Coronium on first deploy. Example: https://my-reseller-shop.vercel.app
# Leave empty in local dev.
RESELLER_PUBLIC_URL=

# Optional shared secret appended to your webhook URL as a query param so you
# can verify the request originated from our delivery service. Coronium will
# include it on every POST. Use crypto.randomBytes(32).toString('hex').
WEBHOOK_SECRET=
